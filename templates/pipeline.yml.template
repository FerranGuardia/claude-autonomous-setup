# pipeline.yml — Auto-generated by /setup-project
# DO NOT EDIT MANUALLY unless you know what you're doing.
# Re-run /setup-project to regenerate from real project scan.
#
# Toolkit: {TOOLKIT_ROOT}
# Generated: {TIMESTAMP}

project:
  name: {PROJECT_NAME}
  prefix: {PREFIX}              # e.g., RMP, ORG, PRJ — used for task IDs
  dev-branch: {DEV_BRANCH}      # e.g., develop, main
  branch-pattern: "task/{TASK_ID}-{slug}"

stack:
  # Detected from real project files — see comments for evidence
  ecosystem: {ECOSYSTEM}        # node, python, dotnet, rust, go, java, ruby, php
  framework: {FRAMEWORK}        # next, django, aspnet, rails, etc.
  framework-version: {VERSION}  # exact version from package file
  language: {LANGUAGE}          # typescript, javascript, python, csharp, etc.
  database: {DATABASE}          # supabase, postgres, mysql, mssql, mongodb, sqlite
  styling: {STYLING}            # tailwind, css-modules, styled-components, scss
  testing:
    unit: {UNIT_TEST}           # vitest, jest, pytest, xunit, etc.
    e2e: {E2E_TEST}             # playwright, cypress, selenium, etc.
    components: {COMP_TEST}     # storybook, etc.
  ci-cd: {CI_CD}                # github-actions, gitlab-ci, jenkins, etc.
  hosting: {HOSTING}            # vercel, netlify, docker, hetzner, etc.

skills:
  # Which skills are loaded per agent role
  # Only skills that matched the detected tech are listed here
  task-executor: []
  qa-reviewer: []
  code-simplifier: []
  task-fixer: []
  audit-code-archaeologist: []
  audit-security-auditor: []
  audit-qa-tester: []
  audit-devops-analyst: []
  audit-docs-analyst: []
  audit-requirements-analyst: []

gaps:
  # Tech detected in the project but NO skill exists in the toolkit
  # Agents will use base LLM knowledge for these — be aware of potential hallucination
  # Build skills for these to improve agent accuracy
  # - tech: nextjs
  #   detected-from: next.config.mjs
  #   note: "No skill in toolkit. Agent uses base knowledge."

validation:
  # Commands to run in the merge gate
  typecheck: "N/A"
  lint: "N/A"
  format: "N/A"
  test-unit: "N/A"
  test-e2e: "N/A"
  merge-gate: "N/A"

database:
  # Commands for database operations (if applicable)
  start: "N/A"
  reset: "N/A"
  migrate: "N/A"
  gen-types: "N/A"

docs:
  # Paths to project documentation
  conventions: "N/A"
  entities: "N/A"
  flows: "N/A"
  tasks-index: ".claude/tasks/INDEX.md"

overrides:
  # Project-specific instructions for agents
  # Use these to correct agent behavior for this specific project
  # Example:
  # task-executor: "Use Supabase local (Docker), NOT Supabase Cloud. Always check RLS policies."
